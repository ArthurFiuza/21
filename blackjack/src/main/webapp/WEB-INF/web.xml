<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0"
         metadata-complete="true">

  <display-name>blackjack</display-name>

  <welcome-file-list>
    <welcome-file>Index.html</welcome-file>
    <welcome-file>index.html</welcome-file>
    <welcome-file>index.jsp</welcome-file>
  </welcome-file-list>

  <!-- Servlet para criar sala / iniciar jogo -->
  <servlet>
    <servlet-name>IniciarJogoServlet</servlet-name>
    <servlet-class>servlet.IniciarJogoServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>IniciarJogoServlet</servlet-name>
    <url-pattern>/iniciar</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>IniciarJogoServlet</servlet-name>
    <url-pattern>/IniciarJogoServlet</url-pattern>
  </servlet-mapping>

  <!-- Servlet para entrar em sala -->
  <servlet>
    <servlet-name>EntrarSalaServlet</servlet-name>
    <servlet-class>servlet.EntrarSalaServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>EntrarSalaServlet</servlet-name>
    <url-pattern>/entrar</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>EntrarSalaServlet</servlet-name>
    <url-pattern>/EntrarSalaServlet</url-pattern>
  </servlet-mapping>

  <!-- Servlet para comprar carta -->
  <servlet>
    <servlet-name>ComprarCartaServlet</servlet-name>
    <servlet-class>servlet.ComprarCartaServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>ComprarCartaServlet</servlet-name>
    <url-pattern>/ComprarCartaServlet</url-pattern>
  </servlet-mapping>

  <!-- Servlet para parar -->
  <servlet>
    <servlet-name>PararServlet</servlet-name>
    <servlet-class>servlet.PararServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>PararServlet</servlet-name>
    <url-pattern>/PararServlet</url-pattern>
  </servlet-mapping>

</web-app>